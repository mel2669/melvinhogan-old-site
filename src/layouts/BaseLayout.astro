---
import MainNav from "../components/MainNav.astro";
import type { NavKey } from "../types/nav";

type Props = {
  title: string;
  description: string;
  current: NavKey;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  /** Defaults to summary_large_image when ogImage is set, otherwise summary */
  twitterCard?: string;
  bodyClass?: string;
  wfPageId?: string;
  linkedinUrl?: string;
};

const {
  title,
  description,
  current,
  ogTitle,
  ogDescription,
  ogImage,
  twitterTitle,
  twitterDescription,
  twitterCard: twitterCardProp,
  bodyClass = "",
  wfPageId,
  linkedinUrl,
} = Astro.props;

const ogT = ogTitle ?? title;
const ogD = ogDescription ?? description;
const twT = twitterTitle ?? ogT;
const twD = twitterDescription ?? ogD;

const twitterCard =
  twitterCardProp ?? (ogImage ? "summary_large_image" : "summary");

const ogImageAbsolute =
  ogImage != null && ogImage !== ""
    ? new URL((ogImage.startsWith("/") ? ogImage.slice(1) : ogImage), Astro.site).href
    : undefined;

const htmlAttrs = {
  "data-wf-domain": "www.melvinhogan.com",
  "data-wf-site": "5f7f7c03bae46f44fc34ddf4",
  lang: "en-US",
  ...(wfPageId ? { "data-wf-page": wfPageId } : {}),
};
---

<!doctype html>
<html {...htmlAttrs}>
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta content={description} name="description" />
    <meta content={ogT} property="og:title" />
    <meta content={ogD} property="og:description" />
    {ogImageAbsolute && <meta content={ogImageAbsolute} property="og:image" />}
    <meta content={twT} property="twitter:title" />
    <meta content={twD} property="twitter:description" />
    <meta property="og:type" content="website" />
    <meta content={twitterCard} name="twitter:card" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <meta
      content="google-site-verification=HycEq3nwcD_qxYslXGdESdDc0owT1iNf2JlkakxrjsE"
      name="google-site-verification"
    />
    <meta name="p:domain_verify" content="75b2ec126cf8959c4da788cb3b586a00" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link href="/assets/css/google-fonts.css" rel="stylesheet" type="text/css" />
    <link href="/assets/css/webflow.bundle.css" rel="stylesheet" type="text/css" />
    <link href="/assets/css/font-overrides.css" rel="stylesheet" type="text/css" />
    <link href="/assets/css/typography.css" rel="stylesheet" type="text/css" />
    <script is:inline>
      !(function (o, c) {
        var n = c.documentElement,
          t = " w-mod-";
        n.className += t + "js";
        ("ontouchstart" in o ||
          (o.DocumentTouch && c instanceof DocumentTouch)) &&
          (n.className += t + "touch");
      })(window, document);
    </script>
    <link href="/assets/images/683076d780fd523927c18d20_MehLogoIco.png" rel="shortcut icon" type="image/x-icon" />
    <link href="/assets/images/683078107d431cc67115b34c_MehLogo.png" rel="apple-touch-icon" />
  </head>
  <body class={bodyClass}>
    <MainNav current={current} linkedinUrl={linkedinUrl} />
    <slot />
    <script src="/assets/js/jquery-3.5.1.min.js" type="text/javascript"></script>
    <script src="/assets/js/webflow.schunk.57d5559d2f0cd9f8.js" type="text/javascript"></script>
    <script src="/assets/js/webflow.schunk.3b94eee02e342815.js" type="text/javascript"></script>
    <script src="/assets/js/webflow.2f121503.6823c5431fc3f984.js" type="text/javascript"></script>
    <script src="/assets/js/before-after-slider.min.js" type="text/javascript"></script>
  </body>
</html>
