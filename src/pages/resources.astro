---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  groupBookmarksByCategory,
  loadInspirationBookmarksFromRepo,
} from "../lib/inspirationBookmarks";

const bookmarks = loadInspirationBookmarksFromRepo();
const byCategory = groupBookmarksByCategory(bookmarks);
---

<BaseLayout
  title="Melvin Hogan | Resources & inspiration"
  description="Curated links, articles, and references worth returning to."
  ogTitle="Melvin Hogan | Resources & inspiration"
  ogDescription="Curated links, articles, and references worth returning to."
  twitterTitle="Melvin Hogan | Resources & inspiration"
  twitterDescription="Curated links, articles, and references worth returning to."
  current="resources"
>
  <main id="main-content">
    <section data-w-id="res-title" style="opacity:0" class="sitetitle">
      <div class="w-layout-blockcontainer w-container">
        <h1 class="main-headline">Resources & inspiration</h1>
      </div>
    </section>
    <section class="bio" aria-labelledby="res-intro-heading">
      <h2 id="res-intro-heading" class="sr-only">Introduction</h2>
      <div class="w-layout-blockcontainer container-13 w-container">
        <p data-w-id="res-intro" style="opacity:0" class="callout">
          Articles, tools, and references I return to. The links below are generated at build time from
          <code class="resources-inline-code">src/data/inspiration_bookmarks.csv</code> (export from your Google
          sheet and replace that file to refresh the page).
        </p>
      </div>
    </section>
    <section class="contact resources-float-section" aria-labelledby="res-links-heading">
      <div class="w-layout-blockcontainer w-container resources-links resources-links--float">
        <h2 id="res-links-heading" class="sr-only">Curated links</h2>
        {
          [...byCategory.entries()].map(([category, items]) => (
            <div class="resources-category-block">
              <h3 class="resources-group-heading">{category}</h3>
              <div class="resources-float-stage" data-resources-float>
                {items.map((item) => (
                  <a
                    href={item.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="resources-float-link contactbutton w-button"
                  >
                    {item.title}
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  import { initResourcesFloat } from "../scripts/resources-float.ts";

  function start() {
    requestAnimationFrame(() => {
      requestAnimationFrame(() => initResourcesFloat());
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", start);
  } else {
    start();
  }
</script>
